# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv/
env/
venv/

# VSCode or JetBrains IDEs
.vscode/
.idea/

# Logs and debugging
*.log
*.tmp
*.bak

# OS junk files
.DS_Store
Thumbs.db

# Test results
coverage/
htmlcov/
.tox/
.nox/

# Build artifacts
build/
dist/
*.egg-info/

# Python wheel
*.whl

# Docker
*.pid
*.tar

# Streamlit cache
.streamlit/

# PySide6 UI designer
*.ui

# FastAPI autoreload
**/__pycache__/
**/*.pyc

# Mobile build artifacts
mobile/composeApp/.gradle/
mobile/composeApp/build/
mobile/composeApp/.idea/

# Ignore subtitle output cache
*.srt
*.ass
*.vtt
*.idx
*.sub

# Ignore OCR outputs
*.txt
*.pdf
*.epub
*.docx
*.mobi
*.azw3
